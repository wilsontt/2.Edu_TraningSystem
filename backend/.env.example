# 後端環境變數範例（複製為 backend/.env 後填入實際值）
# ⚠️ 切勿將含真實帳密的 .env 提交版控；SMB 密碼屬機敏資訊。
#
# 跨平台路徑慣例（Windows／macOS 開發、Linux Docker 生產共用同一套值）：
# - SMB_*／MATERIALS_ROOT／BACKUP_ROOT 是「NAS 邏輯路徑」，不是本機磁碟路徑。
# - 一律以 / 分段；禁止 D:\...、/mnt/...、\\server\share\...。
# - 開發：backend/.env（程式以 config.py 位置載入，不依賴 cwd）。
# - 生產 Docker：以 compose／環境變數注入（映像不含 .env）。
# 詳見：1.docs/00-專案總覽/NAS與路徑跨平台慣例.md

# --- AD 設定 ---
AD_ENABLED=true
AD_SERVER_URI=ldap://sampledomanin.com:389  # 請改 DC 的 IP 或主機名稱，例如 ldap://192.168.x.x:389
AD_USE_SSL=false
AD_BASE_DN=DC=sampledomanin,DC=com
AD_DOMAIN=sampledomanin.com
AD_ADMIN_GROUP=Admin                        # 確認 DC 上允許登入的群組名稱（預設 IT Admins）

# 請設 JWT_SECRET_KEY 作為簽發 HS256 JWT 的信任密鑰
# cd backend
# 32 bytes 或 64 個十六進位字元
# openssl rand -hex 32  # macOS/Linux 通常可用
# .venv/bin/python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=請改為強密鑰（隨機產生至少 32 字元）

AD_FALLBACK_EMAIL_ENABLED=false             # 改成 true，OTP 備援才會啟用

# ---- 以下 SMTP 設定 ----
SMTP_HOST=                                  # ※ 寄信伺服器（例如 smtp.gmail.com 或公司 Exchange）
SMTP_PORT=587                               # ※ 通常 587（STARTTLS）或 465（SSL）
SMTP_USER=                                  # ※ SMTP 登入帳號
# 加密現有 SMTP 明文密碼（輸出整行）
# .\.venv\Scripts\python.exe scripts/encrypt_env_secret.py "你的SMTP明文密碼"
SMTP_PASSWORD=                              # 建議 enc:<Fernet密文>（scripts/encrypt_env_secret.py）；明文相容但啟動警告
SMTP_FROM=                                  # ※ 寄件者顯示地址，如 noreply@example.com
SMTP_USE_TLS=true

# --- NAS / SMB 共用（三模式共用伺服器與共享）---
# SMB_SERVER：主機名或 IP（不可含路徑）
SMB_SERVER=192.168.1.10
# SMB_SHARE：僅共享名稱（建議）；子目錄請放 MATERIALS_ROOT
# 相容寫法：CrownWork/教育訓練教材及考卷（程式會拆段組成 UNC）
SMB_SHARE=CrownWork
# 教材 NAS 登入：純帳號時自動補網域（優先於 AD_DOMAIN）；含 . 用 user@domain，否則 DOMAIN\user
SMB_AUTH_DOMAIN=

# NAS 共享內相對根目錄（邏輯路徑，一律 / 分段）
# 最終 UNC：\\{SMB_SERVER}\{SMB_SHARE}\{MATERIALS_ROOT}\...
MATERIALS_ROOT=教育訓練教材及考卷/materials
BACKUP_ROOT=教育訓練教材及考卷/backups

# --- 考卷 TXT：service 模式專用帳號（環境變數，勿入版控、勿入 DB）---
EXAM_SMB_USERNAME=
EXAM_SMB_PASSWORD=

# --- 教材限額（Wave 3；可省略則用程式預設）---
# TEACHING_MATERIAL_MAX_FILE_BYTES=52428800        # 50MB 全系統硬上限
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_COUNT=5       # 單次上傳檔數
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_BYTES=104857600   # 100MB 單次上傳總量
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_COUNT=10    # 批次下載檔數
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_BYTES=209715200 # 200MB 批次下載總量
# EXAM_TXT_MAX_FILE_BYTES=5242880                  # 5MB 考卷 TXT 專用
# NAS_SESSION_TTL_SECONDS=600                       # 教材 NAS 登入 token 有效秒數

# 排程備份 backup 模式帳號於「排程管理」設定（加密儲存），不在此檔（見 Wave 4）。

# --- 排程備份（Wave 4）：加密 backup_nas_password 用的密鑰，僅需設定、勿洩漏 ---
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_CREDENTIAL_SECRET=
