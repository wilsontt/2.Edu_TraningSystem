# 後端環境變數範例（複製為 backend/.env 後填入實際值）
# ⚠️ 切勿將含真實帳密的 .env 提交版控；SMB 密碼屬機敏資訊。

# --- NAS / SMB 共用（三模式共用伺服器與共享）---
SMB_SERVER=192.168.1.10
SMB_SHARE=CrownWork

# NAS 共享內的根目錄（相對路徑）
MATERIALS_ROOT=materials
BACKUP_ROOT=backups

# --- 考卷 TXT：service 模式專用帳號（環境變數，不入版控／不入 DB）---
EXAM_SMB_USERNAME=
EXAM_SMB_PASSWORD=

# 排程備份 backup 模式帳號於「排程管理」設定（加密儲存），不在此檔（見 Wave 4）。
