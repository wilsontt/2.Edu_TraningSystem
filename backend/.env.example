# 後端環境變數範例（複製為 backend/.env 後填入實際值）
# ⚠️ 切勿將含真實帳密的 .env 提交版控；SMB 密碼屬機敏資訊。

# --- AD 設定 ---
AD_ENABLED=true
AD_SERVER_URI=ldap://sampledomanin.com:389  # 填 DC 的 IP 或主機名稱，例如 ldap://192.168.x.x:389
AD_USE_SSL=false
AD_BASE_DN=DC=sampledomanin,DC=com
AD_DOMAIN=sampledomanin.com
AD_ADMIN_GROUP=IT Admins                     # 確認 DC 上允許登入的群組名稱（預設 IT Admins）

# 產生 JWT_SECRET_KEY 用來簽署 HS256 JWT 的隨機金鑰
# cd backend
# 32 bytes → 64 個十六進位字元
# openssl rand -hex 32  # macOS/Linux 通常會有
# .venv/bin/python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=請換成強密鑰（隨機產生至少 32 字元）

AD_FALLBACK_EMAIL_ENABLED=false             # 改成 true，OTP 備援就能啟用

# ---- 以下 SMTP 欄位 ----
SMTP_HOST=                                  # ← 填寄信伺服器（如 smtp.gmail.com 或公司 Exchange）
SMTP_PORT=587                               # ← 通常 587（STARTTLS）或 465（SSL）
SMTP_USER=                                  # ← SMTP 登入帳號
SMTP_PASSWORD=                              # ← SMTP 密碼（機敏，不入版控）
SMTP_FROM=                                  # ← 寄件者顯示地址，如 noreply@crownvan.com
SMTP_USE_TLS=true

# --- NAS / SMB 共用（三模式共用伺服器與共享）---
SMB_SERVER=192.168.1.10
SMB_SHARE=CrownWork/教育訓練教材及考卷

# NAS 共享內的根目錄（相對路徑）
MATERIALS_ROOT=materials
BACKUP_ROOT=backups

# --- 考卷 TXT：service 模式專用帳號（環境變數，不入版控／不入 DB）---
EXAM_SMB_USERNAME=
EXAM_SMB_PASSWORD=

# --- 教材庫限額（Wave 3；可留空用程式預設）---
# TEACHING_MATERIAL_MAX_FILE_BYTES=52428800        # 50MB 單檔硬上限
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_COUNT=5       # 單次上傳檔數
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_BYTES=104857600   # 100MB 單次上傳總量
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_COUNT=10    # 批次下載檔數
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_BYTES=209715200 # 200MB 批次下載總量
# EXAM_TXT_MAX_FILE_BYTES=5242880                  # 5MB 考卷 TXT 專用
# NAS_SESSION_TTL_SECONDS=600                       # 教材 NAS 登入 token 有效秒數

# 排程備份 backup 模式帳號於「排程管理」設定（加密儲存），不在此檔（見 Wave 4）。

# --- 排程備份（Wave 4）：加密 backup_nas_password 用的金鑰，務必設定且妥善保管 ---
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKUP_CREDENTIAL_SECRET=
