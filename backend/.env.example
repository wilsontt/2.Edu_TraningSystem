# 後端環境變數範例（複製為 backend/.env 後填入實際值）
# ⚠️ 切勿將含真實帳密的 .env 提交版控；SMB 密碼屬機敏資訊。

# --- NAS / SMB 共用（三模式共用伺服器與共享）---
SMB_SERVER=192.168.1.10
SMB_SHARE=CrownWork/教育訓練教材及考卷

# NAS 共享內的根目錄（相對路徑）
MATERIALS_ROOT=materials
BACKUP_ROOT=backups

# --- 考卷 TXT：service 模式專用帳號（環境變數，不入版控／不入 DB）---
EXAM_SMB_USERNAME=
EXAM_SMB_PASSWORD=

# --- 教材庫限額（Wave 3；可留空用程式預設）---
# TEACHING_MATERIAL_MAX_FILE_BYTES=52428800        # 50MB 單檔硬上限
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_COUNT=5       # 單次上傳檔數
# TEACHING_MATERIAL_MAX_BATCH_UPLOAD_BYTES=104857600   # 100MB 單次上傳總量
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_COUNT=10    # 批次下載檔數
# TEACHING_MATERIAL_MAX_BATCH_DOWNLOAD_BYTES=209715200 # 200MB 批次下載總量
# EXAM_TXT_MAX_FILE_BYTES=5242880                  # 5MB 考卷 TXT 專用
# NAS_SESSION_TTL_SECONDS=600                       # 教材 NAS 登入 token 有效秒數

# 排程備份 backup 模式帳號於「排程管理」設定（加密儲存），不在此檔（見 Wave 4）。
